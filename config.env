KERNEL_SOURCE=https://github.com/543069760/Nethunter-KVM-Docker_kernel-v1_Redmi-k40gaming
KERNEL_SOURCE_BRANCH=aex9
KERNEL_DEFCONFIG=nethunter-kvm-docker-ares_defconfig
TARGET_ARCH=arm64
KERNEL_FILE=Image.gz-dtb
CLANG_VERSION=r416183b
DISABLE-LTO=true
USE_KERNELSU=true
USE_KPROBES=true
USE_OVERLAYFS=true
NEED_DTBO=false
MAKE_BOOT_IMAGE=true
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/xiaoleGun/KernelSU_action/main/boot/boot-wayne-from-Miku-UI-latest.img
